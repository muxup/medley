# A shared sandbox tool, providing at least some filesystem isolation for
# less trusted applications using unshare and nsenter. See
# https://muxup.com/shandbox for more details.
#
# Two sets of namespaces are used to provide this isolation: the outer
# 'shandbox_root' has the user mapped to root within the namespace and retains
# access to standard / (allowing us to mount additional paths into after the
# sandbox has started). The inner 'shandbox_user' represents a new user
# namepsace mapping our uid/gid to an unprivileged user, but other namespaces
# are shared with 'shandbox_root'. Sandboxed processes are launched within
# the namespaces of 'shandbox_user'.
#
# By convention, paths in variables prefixed with `SB_` are paths from the
# perspective of within the sandbox. Other paths are from the perspective of
# our normal unmodified filesystem layout.
#
# Within the sandbox, HOME is /home/sandbox. On the host, the sandbox
# directory is selected by the SANDBOX_DIR environment variable, defaulting to
# $HOME/sandbox. All shandbox state for a given sandbox lives within
# $SANDBOX_DIR/.shandbox_meta, which is shadowed from the guest by a tmpfs
# overmount so it is neither visible nor writable from inside the sandbox.

# Configuration options you may want to edit.
SB_HOME="/home/sandbox"
SB_PATH="$SB_HOME/.local/bin:$SB_HOME/bin:/usr/local/bin:/usr/bin"

# Derived paths.
SANDBOX_DIR="${SANDBOX_DIR:-$HOME/sandbox}"
META_DIR="$SANDBOX_DIR/.shandbox_meta"
CHROOT_DIR="$META_DIR/root"
RUN_DIR="$META_DIR/run"
LOG_FILE="$META_DIR/log"
INIT_HOOK="$META_DIR/init"
SHANDBOX_ROOT_PIDREF=
SHANDBOX_USER_PIDREF=

die() {
  printf "%s\n" "$*" >&2
  exit 1
}

log() {
  printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE"
  printf '%s\n' "$*"
}

# Resolve a sandbox-side path, prepending $SB_HOME for non-absolute paths.
resolve_sandbox_path() {
  case "$1" in
    ./*|../*) return 1 ;;
    /*)       printf '%s\n' "$1" ;;
    *)        printf '%s\n' "$SB_HOME/$1" ;;
  esac
}

canonical_target_path() {
  # Ensure the path stays within the sandbox root, and reject /.
  local dest="$1"
  local target
  [ "$dest" != "/" ] || return 1
  target="$(realpath -m "$CHROOT_DIR$dest")" || return 1
  [ "${target#"$CHROOT_DIR"/}" != "$target" ] || return 1
  printf '%s\n' "$target"
}

# To protect against PID wraparound, we store more than just the PID. For
# systems with new enough util-linux, we can't use getino to get a pid:inode
# reference that is also accepted by kill and  nsenter. On older systems we
# instead get the process start time from the processes' stat file and store
# that as pid@start_time.

# Return the process start time from /proc/PID/stat.
pid_start_time() {
  local stat start_time
  [ -r "/proc/$1/stat" ] || return 1
  read -r stat < "/proc/$1/stat" 2>/dev/null || return 1
  stat="${stat##*) }"
  start_time="$(printf '%s\n' "$stat" | cut -d ' ' -f20)" || return 1
  printf '%s\n' "$start_time"
}

make_pidref() {
  local pidref
  if command -v getino >/dev/null 2>&1; then
    pidref="$(getino -p "$1" 2>/dev/null)" || true
    if [ -n "$pidref" ]; then
      printf '%s\n' "$pidref"
      return
    fi
  fi
  printf '%s@%s\n' "$1" "$(pid_start_time "$1")"
}

# Read the pidref from one of our named pid files and print it, returning
# non-zero on failure. Perform some basic validation that we have a pidref that
# still refers to a running process. For pid@start_time refs, print just the
# pid so the result can be used directly with tools expecting a pid.
read_pidref() {
  local pidfile="$META_DIR/${1}_pid"
  local pidref start_time
  [ -r "$pidfile" ] || return 1
  read -r pidref < "$pidfile" 2>/dev/null || return 1
  case "$pidref" in
    [0-9]*:[0-9]*)
      /usr/bin/kill -s 0 "$pidref" >/dev/null 2>&1 || return 1
      ;;
    [0-9]*@[0-9]*)
      start_time="$(pid_start_time "${pidref%%@*}")" || return 1
      [ "${pidref#*@}" = "$start_time" ] || return 1
      pidref="${pidref%%@*}"
      ;;
    *) return 1 ;;
  esac
  printf '%s\n' "$pidref"
}

# Get the pid of the first child, returning non-zero on failure.
find_child() {
  local child
  read -r child _ < "/proc/$1/task/$1/children" 2>/dev/null || true
  [ -n "$child" ] && echo "$child"
}

require_shandbox_root_pid() {
  SHANDBOX_ROOT_PIDREF="$(read_pidref shandbox_root)" || die "shandbox root pid not found"
}

require_shandbox_user_pid() {
  SHANDBOX_USER_PIDREF="$(read_pidref shandbox_user)" || die "shandbox user pid not found"
}

nsenter_shandbox_root() {
  nsenter --preserve-credentials -U -m -i -p -t "$SHANDBOX_ROOT_PIDREF" -- "$@"
}

is_running() {
  read_pidref shandbox_user >/dev/null 2>&1
}

# Start the sandbox if it doesn't appear to be running.
ensure_running() {
  is_running || cmd_start
}

run_init_hook() {
  [ -x "$INIT_HOOK" ] || return 0

  SHANDBOX_SELF="$0" \
  SANDBOX_DIR="$SANDBOX_DIR" \
  SB_HOME="$SB_HOME" \
  SB_PATH="$SB_PATH" \
  "$INIT_HOOK"
}

# Set up the .shandbox_meta layout under the given sandbox directory, creating
# the directory itself if it does not already exist. Used by 'shandbox new'
# and implicitly by 'shandbox start' on an uninitialised SANDBOX_DIR.
init_sandbox_dir() {
  local dir="$1"
  mkdir -p "$dir/.shandbox_meta/root" "$dir/.shandbox_meta/run" \
    || die "failed to initialise sandbox layout under $dir"
  printf 'initialised sandbox at %s\n' "$dir"
  printf 'to use this sandbox, set: SANDBOX_DIR=%s\n' "$dir"
  printf 'to add an init hook, create an executable script at: %s/.shandbox_meta/init\n' "$dir"
}

cmd_new() {
  [ $# -eq 1 ] || die "usage: shandbox new <dir>"
  [ ! -e "$1" ] || [ -d "$1" ] || die "$1 exists and is not a directory"
  init_sandbox_dir "$1"
}

# Start the sandbox by ensuring the necessary root layout is in place, then
# creating the namespaces and recording the pids of the processes associated
# with them.
cmd_start() {
  [ $# -eq 0 ] || die "usage: shandbox start"
  local pidref
  if pidref="$(read_pidref shandbox_user)"; then
    die "already running (pid ${pidref%%:*})"
  fi

  # Implicitly initialise the sandbox layout if needed.
  if [ ! -d "$META_DIR" ]; then
    init_sandbox_dir "$SANDBOX_DIR"
  fi

  # Fresh-start housekeeping: rotate the log, clear stale pid files, the old
  # passwd, and the contents of the in-guest /run/user bind source.
  if [ -f "$LOG_FILE" ]; then
    mv -f "$LOG_FILE" "$LOG_FILE.old"
  fi
  touch "$LOG_FILE"
  rm -f "$META_DIR/shandbox_root_pid" "$META_DIR/shandbox_user_pid" "$META_DIR/passwd"
  rm -rf "$RUN_DIR"
  mkdir -p "$RUN_DIR"

  local sb_uid="$(id -u)"
  local sb_gid="$(id -g)"

  # Set up a fake /etc/passwd so the user within the sandbox appears as
  # 'sandbox'.
  cat - <<EOF > "$META_DIR/passwd"
root:x:0:0::/root:/usr/bin/nologin
nobody:x:65534:65534::/:/usr/bin/nologin
sandbox:x:$sb_uid:$sb_gid::/home/sandbox:/usr/bin/bash
EOF

  # Create the 'shandbox_root' sandbox which includes the shared mount
  # namespace, perform mounts, then set up the 'shandbox_user' inner namespace
  # that will be used for launching programs. We set the variables needed for
  # the heredoc script as environment variables. Mounts will happen within the
  # outer 'shandbox_root' environment. Each dir or file mount requires that a
  # dir/file with that name exists already. For simplicity, we do the
  # necessary mkdir/touch just before the mount, within the script passed to
  # 'unshare'.
  CHROOT_DIR="$CHROOT_DIR" \
  SANDBOX_DIR="$SANDBOX_DIR" \
  META_DIR="$META_DIR" \
  RUN_DIR="$RUN_DIR" \
  SB_UID="$sb_uid" \
  SB_GID="$sb_gid" \
  SB_HOME="$SB_HOME" \
  SB_PATH="$SB_PATH" \
  unshare --mount --ipc --pid --user --fork --kill-child --map-root-user -- \
    /bin/sh <<'EOF' &
set -eu
mount --make-rprivate /
mount --bind "$CHROOT_DIR" "$CHROOT_DIR"
for p in /bin /sbin /lib /lib64 /lib32 /usr /etc /opt /sys /run/systemd/resolve; do
  [ -e "$p" ] || continue
  mkdir -p "$CHROOT_DIR$p"
  mount -o rbind,ro,nosuid,nodev "$p" "$CHROOT_DIR$p"
done
mount -o bind,ro "$META_DIR/passwd" "$CHROOT_DIR/etc/passwd"
mkdir -p "$CHROOT_DIR/run/user/$SB_UID"
mount -o bind,nosuid,nodev "$RUN_DIR" "$CHROOT_DIR/run/user/$SB_UID"
mkdir -p "$CHROOT_DIR/dev"
mount -t tmpfs -o nosuid,noexec,mode=0755,size=64k tmpfs "$CHROOT_DIR/dev"
for d in null zero full random urandom tty; do
  touch "$CHROOT_DIR/dev/$d"
  mount -o bind "/dev/$d" "$CHROOT_DIR/dev/$d"
done
mkdir -p "$CHROOT_DIR/dev/pts"
mount -t devpts devpts "$CHROOT_DIR/dev/pts" -o newinstance,ptmxmode=0666
ln -sf pts/ptmx "$CHROOT_DIR/dev/ptmx"
mkdir -p "$CHROOT_DIR/dev/shm"
ln -sf /proc/self/fd "$CHROOT_DIR/dev/fd"
ln -sf /proc/self/fd/0 "$CHROOT_DIR/dev/stdin"
ln -sf /proc/self/fd/1 "$CHROOT_DIR/dev/stdout"
ln -sf /proc/self/fd/2 "$CHROOT_DIR/dev/stderr"
mkdir -p "$CHROOT_DIR/tmp"
mount -o rbind,nosuid,nodev /tmp "$CHROOT_DIR/tmp"
mkdir -p "$CHROOT_DIR/home/sandbox"
mount -o bind,nosuid,nodev "$SANDBOX_DIR" "$CHROOT_DIR/home/sandbox"
# Shadow the host-side .shandbox_meta directory from the guest with an empty,
# unreadable tmpfs so the guest can't see or tamper with sandbox state.
mount -t tmpfs -o nosuid,noexec,nodev,size=4k,mode=0,nr_inodes=1 tmpfs \
  "$CHROOT_DIR/home/sandbox/.shandbox_meta"
mkdir -p "$CHROOT_DIR/proc"
mount -t proc proc "$CHROOT_DIR/proc"
env -i HOME="$SB_HOME" PATH="$SB_PATH" TERM="${TERM:-xterm}" XDG_RUNTIME_DIR="/run/user/$SB_UID" \
  unshare --user --map-user="$SB_UID" --map-group="$SB_GID" --root="$CHROOT_DIR" -- \
  sleep infinity &
wait
EOF
  local shandbox_root_pid shandbox_user_pid shandbox_root_pidref shandbox_user_pidref
  local unshare_pid=$!
  local i=0
  while [ "$i" -lt 5 ]; do
    if shandbox_root_pid=$(find_child "$unshare_pid"); then
      if shandbox_user_pid=$(find_child "$shandbox_root_pid"); then
        if [ "$(cat "/proc/$shandbox_user_pid/comm" 2>/dev/null)" = "sleep" ]; then
          break
        fi
      fi
    fi
    sleep 0.1
    i=$((i + 1))
  done
  [ "$shandbox_user_pid" ] || die "failed to start"
  shandbox_root_pidref="$(make_pidref "$shandbox_root_pid")" || die "failed to get shandbox root pidref"
  shandbox_user_pidref="$(make_pidref "$shandbox_user_pid")" || die "failed to get shandbox user pidref"
  echo "$shandbox_root_pidref" > "$META_DIR/shandbox_root_pid"
  echo "$shandbox_user_pidref" > "$META_DIR/shandbox_user_pid"
  log "started (pid $shandbox_user_pid)"
  if ! run_init_hook; then
    cmd_stop >/dev/null 2>&1 || true
    die "init hook failed: $INIT_HOOK"
  fi
}

# Attempt to kill the 'shandbox_user' process, which should result in
# 'shandbox_root' terminating as well.
cmd_stop() {
  [ $# -eq 0 ] || die "usage: shandbox stop"
  local i
  is_running || die "not running"
  require_shandbox_user_pid
  /usr/bin/kill "$SHANDBOX_USER_PIDREF" 2>/dev/null || true
  i=0
  while [ "$i" -lt 20 ] && is_running; do sleep 0.1; i=$((i + 1)); done
  rm -f "$META_DIR/shandbox_root_pid" "$META_DIR/shandbox_user_pid"
  log "stopped"
}

cmd_status() {
  [ $# -eq 0 ] || die "usage: shandbox status"
  if ! is_running; then
    echo "stopped"
    return 1
  fi

  require_shandbox_user_pid
  printf 'running (pid %s)\n\n' "${SHANDBOX_USER_PIDREF%%:*}"
  printf 'log:\n'
  tail -20 "$LOG_FILE" 2>/dev/null | sed 's/^/  /'
}

# Translate the host PWD to an in-sandbox path if it's trivial to do so (i.e.
# the path is within the sandbox home).
sandbox_wd() {
  case "$PWD" in
    "$SANDBOX_DIR"/*) echo "$SB_HOME${PWD#"$SANDBOX_DIR"}" ;;
    "$SANDBOX_DIR")   echo "$SB_HOME" ;;
    *)                echo "$SB_HOME" ;;
  esac
}

# Run the given command within the namespaces associated with the
# 'shandbox_user' process. The current working directory will be translated to
# an in-sandbox path if this can be done trivially. Environment variables are
# not passed through.
cmd_run() {
  [ $# -ge 1 ] || die "usage: shandbox run <command> [args...]"
  ensure_running
  require_shandbox_user_pid

  exec nsenter --preserve-credentials --env -U -m -i -p --root --wdns="$(sandbox_wd)" \
    -t "$SHANDBOX_USER_PIDREF" -- "$@"
}

cmd_enter() {
  [ $# -eq 0 ] || die "usage: shandbox enter"
  cmd_run /usr/bin/bash
}

cmd_enter_root() {
  [ $# -eq 0 ] || die "usage: shandbox enter-root"
  ensure_running
  require_shandbox_root_pid
  nsenter_shandbox_root /usr/bin/bash
}

# Bind-mount a host path into the running sandbox.
cmd_add_mount() {
  local mount_opts="rbind,ro,nosuid"
  if [ $# -gt 0 ] && [ "$1" = "--read-write" ]; then
    mount_opts='rbind,nosuid'
    shift
  fi
  [ $# -eq 1 ] || [ $# -eq 2 ] || die "usage: shandbox add-mount [--read-write] <host-path> [<sandbox-path>]"

  is_running || die "not running"

  # Canonicalise paths and check we're not trying to mount at / or specify a
  # path that tries to escape the sandbox root (e.g. through ../../). For the
  # latter, we check the canonicalised target path starts with '$CHROOT_DIR/'.
  local src dest target
  src="$(realpath -e "$1")" || die "source path does not exist: $1"
  if [ $# -eq 2 ]; then
    dest="$(resolve_sandbox_path "$2")" || die "invalid sandbox path: $2"
  else
    dest="$(resolve_sandbox_path "$(basename "$src")")" || die "invalid sandbox path: $(basename "$src")"
  fi
  target="$(canonical_target_path "$dest")" || die "invalid sandbox path: $dest"

  # Perform the requested mount in the context of 'shandbox_root'. The mount
  # point must also be created within that namespace, as we can't always
  # easily determine what host-side path would match the desired path within
  # the namespace. It's necessary to create the directory or file prior to
  # mounting.
  require_shandbox_root_pid
  local mkdir_target="$target"
  if [ ! -d "$src" ]; then
    mkdir_target="$(dirname "$target")"
  fi
  nsenter_shandbox_root mkdir -p "$mkdir_target" \
    || die "failed to create mount point"
  if [ ! -d "$src" ]; then
    nsenter_shandbox_root touch "$target" \
      || die "failed to create mount point"
  fi
  nsenter_shandbox_root mount -o "$mount_opts" "$src" "$target" \
    || die "mount failed"
  log "mounted $src -> $dest"
}

# Take the given path and try to umount it within the 'shandbox_root'
# namespace.
cmd_remove_mount() {
  [ $# -eq 1 ] || die "usage: shandbox remove-mount <sandbox-path>"
  is_running || die "not running"

  local dest target
  dest="$(resolve_sandbox_path "$1")" || die "invalid sandbox path: $1"
  require_shandbox_root_pid
  target="$(canonical_target_path "$dest")" || die "invalid sandbox path: $dest"
  nsenter_shandbox_root umount "$target" || die "umount failed"
  log "unmounted $dest"
}

cmd_list_mounts() {
  local findmnt_args="-R /home/sandbox"
  if [ $# -eq 1 ] && [ "$1" = "--all" ]; then
    findmnt_args=
  elif [ $# -ne 0 ]; then
    die "usage: shandbox list-mounts [--all]"
  fi
  is_running || die "not running"
  require_shandbox_user_pid
  findmnt -N "${SHANDBOX_USER_PIDREF%%:*}" -l -n -o TARGET,SOURCE $findmnt_args
}

usage() {
  printf 'usage: shandbox {new|start|stop|status|enter|enter-root|run|add-mount|remove-mount|list-mounts}\n' >&2
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

cmd="$1"; shift
case "$cmd" in
  new)          cmd_new "$@" ;;
  start)        cmd_start "$@" ;;
  stop)         cmd_stop "$@" ;;
  status)       cmd_status "$@" ;;
  enter)        cmd_enter "$@" ;;
  enter-root)   cmd_enter_root "$@" ;;
  run)          cmd_run "$@" ;;
  add-mount)    cmd_add_mount "$@" ;;
  remove-mount) cmd_remove_mount "$@" ;;
  list-mounts)  cmd_list_mounts "$@" ;;
  *)            usage; exit 1 ;;
esac
